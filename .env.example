# Copy this file to .env or .env.local for local development.
# Never commit real .env files. Production values belong in Vercel Environment Variables.

# Required. Point this at your Neon/Postgres database.
# Local placeholder example only:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/vyraj_command_console_v2?schema=public"
DATABASE_URL=""

# Required for HMAC hashing officer session tokens before storing them in Postgres.
# Use a long, random, production-safe value per environment.
# Must be 32+ characters and must not be the same as any officer/admin password.
AUTH_SESSION_SECRET=""

# Optional auth settings. Keep AUTH_COOKIE_NAME stable after launch unless you want
# every officer session to be invalidated by a cookie-name change.
AUTH_COOKIE_NAME="vyraj_officer_session"
SESSION_DURATION_HOURS="6"

# Local/dev seed password for Jason Roderick and EmperorVeles.
# Use only for local/dev seeding or an intentional initial production setup.
# Change it before any non-local seed and rotate the seeded passwords afterward.
DEV_SUPER_ADMIN_PASSWORD="VyrajDev!ChangeMe123"
