generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CorpStatus {
  ACTIVE
  TRIAL
  INACTIVE
  ARCHIVED
}

enum OfficerRole {
  SUPER_ADMIN
  ALLIANCE_OFFICER
}

enum OfficerStatus {
  ACTIVE
  DISABLED
}

enum LoginProvider {
  MANUAL
  EVE_SSO
}

enum ContentStatus {
  ACTIVE
  DRAFT
  EXPIRED
  ARCHIVED
}

enum ContentAudience {
  ALL_MEMBERS
  OFFICERS
  SUPER_ADMINS
}

enum AllianceContentType {
  ANNOUNCEMENT
  ALERT
  PRIORITY
  STANDING_ORDER
  FEATURED_OP
  NOTE
}

enum AllianceContentPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

model Corp {
  id                       String     @id @default(uuid()) @db.Uuid
  slug                     String     @unique
  name                     String
  ticker                   String
  description              String     @default("")
  status                   CorpStatus @default(ACTIVE)
  recruitmentStatus        String     @default("Unknown")
  activeMembers            Int        @default(0)
  recentOps                Int        @default(0)
  pendingSrp               Int        @default(0)
  doctrineReadinessPercent Int        @default(0)
  announcements            Json       @default("[]")
  enabledModules           Json       @default("{}")
  createdAt                DateTime   @default(now())
  updatedAt                DateTime   @updatedAt
  legacySheetName          String?
  legacyRowNumber          Int?
  legacyImportedAt         DateTime?

  officerAssignments    OfficerCorpAssignment[]
  officerPermissions    OfficerPermission[]
  auditLogs             OfficerAuditLog[]
  operations            Operation[]
  operationAttendance   OperationAttendance[]
  srpRequests           SrpRequest[]
  doctrineFits          DoctrineFit[]
  doctrineFitReadiness  DoctrineFitReadiness[]
  doctrinePilots        DoctrinePilot[]
  recruitmentApplicants RecruitmentApplicant[]
  lootSplits            LootSplit[]
  eveMemberIdentities   EveIdentity[]           @relation("EveIdentityMemberCorp")
  eveIdentityConfig     CorpEveIdentityConfig?

  @@index([status])
  @@index([legacySheetName, legacyRowNumber])
}

model CorpEveIdentityConfig {
  id                   String    @id @default(uuid()) @db.Uuid
  corpId               String    @unique @db.Uuid
  eveCorporationId     BigInt?   @unique
  eveCorporationName   String    @default("")
  eveTicker            String    @default("")
  ceoId                BigInt?
  ceoName              String    @default("")
  memberCount          Int?
  taxRate              Float?
  creationDate         DateTime?
  eveAllianceId        BigInt?
  eveAllianceName      String    @default("")
  publicDescription    String    @default("")
  publicUrl            String    @default("")
  lastPublicEsiSyncAt  DateTime?
  publicEsiSyncStatus  String    @default("Never Synced")
  publicEsiSyncError   String    @default("")
  syncEnabled          Boolean   @default(false)
  lastVerifiedAt       DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  corp Corp @relation(fields: [corpId], references: [id], onDelete: Cascade)

  @@index([eveAllianceId])
  @@index([syncEnabled])
  @@index([publicEsiSyncStatus])
  @@index([lastPublicEsiSyncAt])
}

model AllianceHubContent {
  id               String                  @id @default(uuid()) @db.Uuid
  contentType      AllianceContentType     @default(ANNOUNCEMENT)
  title            String
  body             String
  audience         ContentAudience         @default(ALL_MEMBERS)
  priority         AllianceContentPriority @default(NORMAL)
  status           ContentStatus           @default(ACTIVE)
  startDate        DateTime?
  endDate          DateTime?
  createdBy        String                  @default("")
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  legacySheetName  String?
  legacyRowNumber  Int?
  legacyImportedAt DateTime?

  @@index([status, audience])
  @@index([startDate, endDate])
  @@index([legacySheetName, legacyRowNumber])
}

model Officer {
  id               String        @id @default(uuid()) @db.Uuid
  officerName      String        @unique
  role             OfficerRole
  passwordHash     String
  status           OfficerStatus @default(ACTIVE)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  lastLoginAt      DateTime?
  disabledAt       DateTime?
  legacySheetName  String?
  legacyRowNumber  Int?
  legacyImportedAt DateTime?

  sessions        OfficerSession[]
  corpAssignments OfficerCorpAssignment[]
  permissions     OfficerPermission[]
  auditLogs       OfficerAuditLog[]
  eveIdentities   EveIdentity[]

  @@index([role, status])
  @@index([legacySheetName, legacyRowNumber])
}

model EveIdentity {
  id                    String        @id @default(uuid()) @db.Uuid
  characterId           BigInt        @unique
  characterName         String
  corporationId         BigInt?
  corporationName       String        @default("")
  allianceId            BigInt?
  allianceName          String        @default("")
  officerId             String?       @db.Uuid
  memberCorpId          String?       @db.Uuid
  provider              LoginProvider @default(EVE_SSO)
  linkedAt              DateTime?
  lastEveLoginAt        DateTime?
  lastIdentityRefreshAt DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  officer    Officer? @relation(fields: [officerId], references: [id], onDelete: SetNull)
  memberCorp Corp?    @relation("EveIdentityMemberCorp", fields: [memberCorpId], references: [id], onDelete: SetNull)

  @@index([corporationId])
  @@index([allianceId])
  @@index([officerId])
  @@index([memberCorpId])
}

model OfficerSession {
  id         String    @id @default(uuid()) @db.Uuid
  officerId  String    @db.Uuid
  tokenHash  String    @unique
  createdAt  DateTime  @default(now())
  expiresAt  DateTime
  revokedAt  DateTime?
  lastSeenAt DateTime?
  userAgent  String?
  ipAddress  String?

  officer Officer @relation(fields: [officerId], references: [id], onDelete: Cascade)

  @@index([officerId])
  @@index([expiresAt])
}

model OfficerCorpAssignment {
  id        String   @id @default(uuid()) @db.Uuid
  officerId String   @db.Uuid
  corpId    String   @db.Uuid
  createdAt DateTime @default(now())

  officer Officer @relation(fields: [officerId], references: [id], onDelete: Cascade)
  corp    Corp    @relation(fields: [corpId], references: [id], onDelete: Cascade)

  @@unique([officerId, corpId])
  @@index([corpId])
}

model OfficerPermission {
  id            String   @id @default(uuid()) @db.Uuid
  officerId     String   @db.Uuid
  permissionKey String
  corpId        String?  @db.Uuid
  createdAt     DateTime @default(now())

  officer Officer @relation(fields: [officerId], references: [id], onDelete: Cascade)
  corp    Corp?   @relation(fields: [corpId], references: [id], onDelete: Cascade)

  @@index([officerId, permissionKey])
  @@index([corpId])
}

model OfficerAuditLog {
  id               String    @id @default(uuid()) @db.Uuid
  officerId        String?   @db.Uuid
  officerName      String    @default("")
  officerRole      String    @default("")
  corpId           String?   @db.Uuid
  corpSlug         String    @default("")
  corpName         String    @default("")
  module           String
  action           String
  permissionUsed   String    @default("")
  targetType       String    @default("")
  targetId         String    @default("")
  targetName       String    @default("")
  summary          String    @default("")
  before           Json?
  after            Json?
  details          Json      @default("{}")
  createdAt        DateTime  @default(now())
  legacySheetName  String?
  legacyRowNumber  Int?
  legacyImportedAt DateTime?

  officer Officer? @relation(fields: [officerId], references: [id], onDelete: SetNull)
  corp    Corp?    @relation(fields: [corpId], references: [id], onDelete: SetNull)

  @@index([corpId, createdAt])
  @@index([module, action])
  @@index([officerId])
  @@index([legacySheetName, legacyRowNumber])
}

model LegacyImportMap {
  id               String   @id @default(uuid()) @db.Uuid
  sourceSystem     String   @default("google_apps_script")
  legacySheetName  String
  legacyRowNumber  Int?
  legacyKey        String?
  targetModel      String
  targetId         String   @db.Uuid
  sourcePayload    Json?
  legacyImportedAt DateTime @default(now())

  @@unique([sourceSystem, legacySheetName, legacyRowNumber, targetModel])
  @@index([targetModel, targetId])
  @@index([legacySheetName])
}

model Operation {
  id               String    @id @default(uuid()) @db.Uuid
  corpId           String    @db.Uuid
  operationCode    String?
  operationName    String
  operationType    String    @default("")
  operationDate    DateTime?
  fcLead           String    @default("")
  location         String    @default("")
  doctrineUsed     String    @default("")
  status           String    @default("Planned")
  notes            String    @default("")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  legacySheetName  String?
  legacyRowNumber  Int?
  legacyImportedAt DateTime?

  corp       Corp                  @relation(fields: [corpId], references: [id], onDelete: Cascade)
  attendance OperationAttendance[]

  @@index([corpId, status])
  @@index([operationDate])
  @@index([legacySheetName, legacyRowNumber])
}

model OperationAttendance {
  id               String    @id @default(uuid()) @db.Uuid
  corpId           String    @db.Uuid
  operationId      String    @db.Uuid
  pilotName        String    @default("")
  characterName    String
  discordName      String    @default("")
  roleFlown        String    @default("")
  shipFlown        String    @default("")
  rewardEligible   String    @default("Not Yet Paid")
  notes            String    @default("")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  legacySheetName  String?
  legacyRowNumber  Int?
  legacyImportedAt DateTime?

  corp      Corp      @relation(fields: [corpId], references: [id], onDelete: Cascade)
  operation Operation @relation(fields: [operationId], references: [id], onDelete: Cascade)

  @@unique([operationId, characterName])
  @@index([corpId])
  @@index([legacySheetName, legacyRowNumber])
}

model SrpRequest {
  id               String    @id @default(uuid()) @db.Uuid
  corpId           String    @db.Uuid
  pilotName        String    @default("")
  characterName    String
  discordName      String    @default("")
  shipLost         String
  killmailLink     String    @default("")
  killmailId       BigInt?
  killmailHash     String    @default("")
  detectedShipTypeId Int?
  detectedShipName String    @default("")
  selectedShipTypeId Int?
  selectedShipName String    @default("")
  shipDetectionSource String @default("none")
  doctrineFleet    String    @default("")
  lossType         String    @default("")
  estimatedValue   Decimal?  @db.Decimal(20, 2)
  killmailTotalValue Decimal? @db.Decimal(20, 2)
  lossValue        Decimal?  @db.Decimal(20, 2)
  insuranceLevelUsed String  @default("Platinum")
  insurancePayout Decimal?  @db.Decimal(20, 2)
  insurancePayoutSource String @default("unknown")
  calculatedEligibleAmount Decimal? @db.Decimal(20, 2)
  calculationSource String  @default("none")
  calculationWarnings String @default("")
  srpAssistStatus String    @default("not_checked")
  srpAssistError  String    @default("")
  srpAssistCheckedAt DateTime?
  requestedPayout  Decimal?  @db.Decimal(20, 2)
  reviewer         String    @default("")
  status           String    @default("New")
  notes            String    @default("")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  legacySheetName  String?
  legacyRowNumber  Int?
  legacyImportedAt DateTime?

  corp Corp @relation(fields: [corpId], references: [id], onDelete: Cascade)

  @@index([corpId, status])
  @@index([killmailId])
  @@index([detectedShipTypeId])
  @@index([selectedShipTypeId])
  @@index([srpAssistStatus])
  @@index([legacySheetName, legacyRowNumber])
}

model SrpInsurancePrice {
  id              String    @id @default(uuid()) @db.Uuid
  typeId          Int       @unique
  typeName        String    @default("")
  platinumPayout  Decimal?  @db.Decimal(20, 2)
  rawLevels       Json      @default("[]")
  fetchStatus     String    @default("not_checked")
  fetchError      String    @default("")
  lastFetchedAt   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([fetchStatus])
  @@index([lastFetchedAt])
}

model DoctrineFit {
  id               String    @id @default(uuid()) @db.Uuid
  corpId           String    @db.Uuid
  doctrineCode     String?
  doctrineName     String
  category         String    @default("")
  shipHull         String    @default("")
  shipTypeId       Int?
  imageUrl         String    @default("")
  manualImageUrl   String    @default("")
  fitText          String    @default("")
  addedBy          String    @default("")
  status           String    @default("Active")
  notes            String    @default("")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  legacySheetName  String?
  legacyRowNumber  Int?
  legacyImportedAt DateTime?

  corp      Corp                   @relation(fields: [corpId], references: [id], onDelete: Cascade)
  readiness DoctrineFitReadiness[]

  @@index([corpId, status])
  @@index([shipTypeId])
  @@index([legacySheetName, legacyRowNumber])
}

model DoctrineFitReadiness {
  id                String    @id @default(uuid()) @db.Uuid
  corpId            String    @db.Uuid
  doctrineFitId     String?   @db.Uuid
  pilotName         String    @default("")
  characterName     String
  discordName       String    @default("")
  readiness         String    @default("Unknown")
  canFlyHull        String    @default("Unknown")
  canUseWeapons     String    @default("Unknown")
  canUseTank        String    @default("Unknown")
  canUsePropUtility String    @default("Unknown")
  missingSkills     String    @default("")
  notes             String    @default("")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  legacySheetName   String?
  legacyRowNumber   Int?
  legacyImportedAt  DateTime?

  corp        Corp         @relation(fields: [corpId], references: [id], onDelete: Cascade)
  doctrineFit DoctrineFit? @relation(fields: [doctrineFitId], references: [id], onDelete: SetNull)

  @@index([corpId, readiness])
  @@index([doctrineFitId])
  @@index([legacySheetName, legacyRowNumber])
}

model DoctrinePilot {
  id               String    @id @default(uuid()) @db.Uuid
  corpId           String    @db.Uuid
  pilotName        String    @default("")
  characterName    String
  discordName      String    @default("")
  primaryRole      String    @default("")
  secondaryRoles   String    @default("")
  tackle           String    @default("Unknown")
  scout            String    @default("Unknown")
  logi             String    @default("Unknown")
  dps              String    @default("Unknown")
  ewar             String    @default("Unknown")
  miningSupport    String    @default("Unknown")
  hauler           String    @default("Unknown")
  pochven          String    @default("Unknown")
  fc               String    @default("Unknown")
  preferredShips   String    @default("")
  missingSkills    String    @default("")
  reviewer         String    @default("")
  status           String    @default("Active")
  notes            String    @default("")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  legacySheetName  String?
  legacyRowNumber  Int?
  legacyImportedAt DateTime?

  corp Corp @relation(fields: [corpId], references: [id], onDelete: Cascade)

  @@index([corpId, status])
  @@index([legacySheetName, legacyRowNumber])
}

model RecruitmentApplicant {
  id                 String    @id @default(uuid()) @db.Uuid
  corpId             String    @db.Uuid
  applicantName      String
  mainCharacter      String    @default("")
  discordName        String    @default("")
  timeZone           String    @default("")
  preferredContent   String    @default("")
  skillPoints        String    @default("")
  source             String    @default("")
  recruitmentChannel String    @default("")
  recruiter          String    @default("")
  status             String    @default("New")
  notes              String    @default("")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  legacySheetName    String?
  legacyRowNumber    Int?
  legacyImportedAt   DateTime?

  corp Corp @relation(fields: [corpId], references: [id], onDelete: Cascade)

  @@index([corpId, status])
  @@index([legacySheetName, legacyRowNumber])
}

model LootSplit {
  id                String    @id @default(uuid()) @db.Uuid
  corpId            String    @db.Uuid
  operationName     String
  operationType     String    @default("")
  totalIskValue     Decimal   @default(0) @db.Decimal(20, 2)
  corpCutPercent    Decimal   @default(0) @db.Decimal(7, 4)
  corpCutAmount     Decimal   @default(0) @db.Decimal(20, 2)
  srpReservePercent Decimal   @default(0) @db.Decimal(7, 4)
  srpReserveAmount  Decimal   @default(0) @db.Decimal(20, 2)
  payoutPool        Decimal   @default(0) @db.Decimal(20, 2)
  totalShares       Decimal   @default(0) @db.Decimal(12, 4)
  createdBy         String    @default("")
  status            String    @default("Ready")
  notes             String    @default("")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  legacySheetName   String?
  legacyRowNumber   Int?
  legacyImportedAt  DateTime?

  corp         Corp                   @relation(fields: [corpId], references: [id], onDelete: Cascade)
  participants LootSplitParticipant[]

  @@index([corpId, status])
  @@index([legacySheetName, legacyRowNumber])
}

model LootSplitParticipant {
  id               String    @id @default(uuid()) @db.Uuid
  lootSplitId      String    @db.Uuid
  pilotName        String
  characterName    String    @default("")
  shares           Decimal   @default(1) @db.Decimal(12, 4)
  payoutAmount     Decimal   @default(0) @db.Decimal(20, 2)
  notes            String    @default("")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  legacySheetName  String?
  legacyRowNumber  Int?
  legacyImportedAt DateTime?

  lootSplit LootSplit @relation(fields: [lootSplitId], references: [id], onDelete: Cascade)

  @@index([lootSplitId])
  @@index([legacySheetName, legacyRowNumber])
}

model EveTypeLookup {
  id               String    @id @default(uuid()) @db.Uuid
  typeName         String    @unique
  typeId           Int?      @unique
  category         String    @default("")
  categoryName     String    @default("")
  groupName        String    @default("")
  renderUrl        String    @default("")
  iconUrl          String    @default("")
  isPublished      Boolean   @default(true)
  lastRefreshedAt  DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  legacySheetName  String?
  legacyRowNumber  Int?
  legacyImportedAt DateTime?

  @@index([category])
  @@index([categoryName])
  @@index([groupName])
  @@index([isPublished])
  @@index([lastRefreshedAt])
  @@index([legacySheetName, legacyRowNumber])
}
